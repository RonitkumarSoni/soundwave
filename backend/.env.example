# Soundwave Backend Environment Variables Template
# Copy this to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# Jamendo API — GET YOUR KEY AT: https://devportal.jamendo.com
JAMENDO_CLIENT_ID=your_jamendo_client_id_here
JAMENDO_API_BASE=https://api.jamendo.com/v3.0

# PostgreSQL — GET FREE DB AT: https://neon.tech or https://supabase.com
DATABASE_URL=postgresql://postgres:password@localhost:5432/soundwave

# JWT Secret — minimum 32 characters
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Redis (optional for v1)
REDIS_URL=redis://localhost:6379

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CORS
CORS_ORIGIN=http://localhost:8082
